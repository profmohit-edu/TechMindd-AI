# Copy to .env and inject real secrets through your deployment secret manager.
TECHMINDD_API_KEYS=replace-with-a-long-random-key
CORS_ORIGINS=http://localhost:5173
RATE_LIMIT_PER_MINUTE=120
ROOT_PATH=
LOG_LEVEL=INFO
LOG_FILE=logs/techmindd.jsonl
LOG_MAX_BYTES=10485760
LOG_BACKUP_COUNT=5

PROVIDER=auto
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_TIMEOUT_SECONDS=60
OPENAI_TEMPERATURE=0.2
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash
GEMINI_TIMEOUT_SECONDS=60
GEMINI_TEMPERATURE=0.2

# Optional ordered override and per-run resilience limits.
PROVIDER_PRIORITY=
PROVIDER_MAX_RETRIES=1
PROVIDER_REQUEST_TIMEOUT_SECONDS=60
RUN_TOKEN_BUDGET=
RUN_COST_BUDGET=
RAG_ENABLED=true
RAG_TOP_K=5
